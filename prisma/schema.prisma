generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id
  email        String
  name         String?
  image        String?
  tasks        Task[]
  habits       Habit[]
  dailyRecords DailyRecord[]
  createdAt    DateTime      @default(now())
}

model Task {
  id          String    @id @default(uuid())
  title       String
  status      String    @default("BACKLOG")
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyItems  DailyPlanItem[]

  @@index([status])
  @@index([userId])
}

model Habit {
  id            String    @id @default(uuid())
  title         String
  defaultCycles Int
  daysOfWeek    Int[]
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyItems  DailyPlanItem[]

  @@index([userId])
}

model DailyRecord {
  date   DateTime
  status String          @default("PLANNING")
  notes  String?
  userId String
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  DailyPlanItem[]

  @@id([date, userId])
  @@index([userId])
}

model DailyPlanItem {
  id              String    @id @default(uuid())
  date            DateTime
  userId          String
  dailyRecord     DailyRecord @relation(fields: [date, userId], references: [date, userId], onDelete: Cascade)
  taskId          String?
  task            Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  habitId         String?
  habit           Habit?    @relation(fields: [habitId], references: [id], onDelete: SetNull)
  title           String
  orderIndex      Int
  estimatedCycles Int
  originalCycles  Int?
  status          String    @default("TODO")
  timeEntries     TimeEntry[]

  @@index([date, status])
  @@index([taskId])
  @@index([habitId])
  @@index([userId])
}

model TimeEntry {
  id              String    @id @default(uuid())
  planItemId      String?   
  planItem        DailyPlanItem? @relation(fields: [planItemId], references: [id], onDelete: Cascade)
  title           String
  startedAt       DateTime
  endedAt         DateTime?
  durationSeconds     Int?
  entryType       String    @default("LIVE_TRACKED")
  notes           String?

  @@index([planItemId])
  @@index([startedAt])
}